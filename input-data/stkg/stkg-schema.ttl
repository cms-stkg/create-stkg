@prefix stkg:    <http://example.org/stkg/> .
@prefix stkgrel: <http://example.org/stkg/relation/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix geo:     <http://www.w3.org/2003/01/geo/wgs84_pos#> .

stkg:Entity a rdfs:Class ;
  rdfs:label "Entity"@en .

stkg:Observation a rdfs:Class ;
  rdfs:label "Observation"@en .

stkg:Platform a rdfs:Class ;
  rdfs:label "Platform"@en .

stkg:PositionObservation a rdfs:Class ;
  rdfs:label "Position Observation"@en .

stkg:SpatialRelationObservation a rdfs:Class ;
  rdfs:label "Spatial Relation Observation"@en .

stkg:observedEntity a rdf:Property ;
  rdfs:domain stkg:PositionObservation ;
  rdfs:range  stkg:Platform ;
  rdfs:label "observed entity"@en .

stkg:time a rdf:Property ;
  rdfs:domain stkg:Observation ;
  rdfs:range  xsd:dateTime ;
  rdfs:label "time"@en .

stkg:subjectEntity a rdf:Property ;
  rdfs:domain stkg:SpatialRelationObservation ;
  rdfs:range  stkg:Platform ;
  rdfs:label "subject entity"@en .

stkg:objectEntity a rdf:Property ;
  rdfs:domain stkg:SpatialRelationObservation ;
  rdfs:range  stkg:Platform ;
  rdfs:label "object entity"@en .

stkg:relationType a rdf:Property ;
  rdfs:domain stkg:SpatialRelationObservation ;
  rdfs:range  rdfs:Resource ;
  rdfs:label "relation type"@en .

stkg:sourceFile a rdf:Property ;
  rdfs:label "source file"@en ;
  rdfs:range xsd:string .

stkg:sourceRow a rdf:Property ;
  rdfs:label "source row index"@en ;
  rdfs:range xsd:integer .