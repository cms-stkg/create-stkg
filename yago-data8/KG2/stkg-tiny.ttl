stkg:objectEntity a rdf:Property ;
    rdfs:label "object entity"@en ;
    rdfs:domain stkg:SpatialRelationObservation ;
    rdfs:range stkg:Platform .

stkg:observedEntity a rdf:Property ;
    rdfs:label "observed entity"@en ;
    rdfs:domain stkg:PositionObservation ;
    rdfs:range stkg:Platform .

stkg:relationType a rdf:Property ;
    rdfs:label "relation type"@en ;
    rdfs:domain stkg:SpatialRelationObservation ;
    rdfs:range rdfs:Resource .

stkg:sourceFile a rdf:Property ;
    rdfs:label "source file"@en ;
    rdfs:domain stkg:Observation ;
    rdfs:range xsd:string .

stkg:sourceRow a rdf:Property ;
    rdfs:label "source row index"@en ;
    rdfs:domain stkg:Observation ;
    rdfs:range xsd:integer .

stkg:subjectEntity a rdf:Property ;
    rdfs:label "subject entity"@en ;
    rdfs:domain stkg:SpatialRelationObservation ;
    rdfs:range stkg:Platform .

stkg:time a rdf:Property ;
    rdfs:label "time"@en ;
    rdfs:domain stkg:Observation ;
    rdfs:range xsd:dateTime .

geo1:lat a rdf:Property ;
    rdfs:label "latitude"@en ;
    rdfs:domain stkg:PositionObservation ;
    rdfs:range xsd:decimal .

geo1:long a rdf:Property ;
    rdfs:label "longitude"@en ;
    rdfs:domain stkg:PositionObservation ;
    rdfs:range xsd:decimal .

<http://example.org/stkg/id/Platform> rdfs:subClassOf stkg:Entity .

<http://example.org/stkg/id/platform_BTR80> a <http://example.org/stkg/id/Platform> .

<http://example.org/stkg/id/PositionObservation> rdfs:subClassOf stkg:Observation .

